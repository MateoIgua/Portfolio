@page "/blog/{Slug}"
@inject BlogService BlogSvc
@inject NavigationManager Nav

<PageTitle>@(_post?.Meta.Title ?? "Cargando...") | Blog</PageTitle>

<section class="section">
    <div class="container post-container">
        @if (_loading)
        {
            <p class="muted">Cargando artículo...</p>
        }
        else if (_post is null)
        {
            <h1>Artículo no encontrado</h1>
            <p class="muted">Es posible que el enlace esté roto o el post haya sido movido.</p>
            <a href="blog" class="btn btn-secondary">← Volver al blog</a>
        }
        else
        {
            <a href="blog" class="back-link mono">← volver</a>
            <header class="post-header">
                <div class="post-meta">
                    <time class="mono muted">@_post.Meta.Date.ToString("yyyy-MM-dd")</time>
                    <span class="muted">·</span>
                    <span class="muted">@_post.Meta.ReadingMinutes min de lectura</span>
                </div>
                <h1>@_post.Meta.Title</h1>
                <div class="post-tags">
                    @foreach (var tag in _post.Meta.Tags)
                    {
                        <span class="tag">@tag</span>
                    }
                </div>
            </header>
            <article class="markdown-content">
                @((MarkupString)_post.HtmlContent)
            </article>
        }
    </div>
</section>

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;

    private BlogPost? _post;
    private bool _loading = true;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _post = await BlogSvc.GetPostAsync(Slug);
        _loading = false;
    }
}

<style>
    .post-container {
        max-width: 760px;
    }

    .back-link {
        display: inline-block;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
        color: var(--text-muted);
    }

    .back-link:hover {
        color: var(--accent);
    }

    .post-header {
        margin-bottom: 2.5rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--border);
    }

    .post-meta {
        display: flex;
        gap: 0.5rem;
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
    }
</style>
