@page "/blog"
@inject BlogService BlogSvc

<PageTitle>Blog | Mateo</PageTitle>

<section class="section">
    <div class="container">
        <p class="mono accent">// blog</p>
        <h1>Blog</h1>
        <p class="lead">Notas, aprendizajes y experimentos.</p>

        @if (_posts is null)
        {
            <p class="muted">Cargando artículos...</p>
        }
        else if (_posts.Count == 0)
        {
            <p class="muted">Aún no hay artículos publicados.</p>
        }
        else
        {
            <ul class="post-list">
                @foreach (var post in _posts)
                {
                    <li>
                        <a href="@($"blog/{post.Slug}")" class="post-item">
                            <div class="post-meta">
                                <time class="mono muted">@post.Date.ToString("yyyy-MM-dd")</time>
                                <span class="muted">·</span>
                                <span class="muted">@post.ReadingMinutes min</span>
                            </div>
                            <h2 class="post-title">@post.Title</h2>
                            <p class="post-summary">@post.Summary</p>
                            <div class="post-tags">
                                @foreach (var tag in post.Tags)
                                {
                                    <span class="tag">@tag</span>
                                }
                            </div>
                        </a>
                    </li>
                }
            </ul>
        }
    </div>
</section>

@code {
    private IReadOnlyList<BlogPostMeta>? _posts;

    protected override async Task OnInitializedAsync()
    {
        _posts = await BlogSvc.GetIndexAsync();
    }
}

<style>
    .lead {
        font-size: 1.1rem;
        margin-bottom: 2.5rem;
    }

    .post-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .post-item {
        display: block;
        padding: 1.5rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        color: inherit;
        transition: all 0.2s ease;
    }

    .post-item:hover {
        border-color: var(--accent);
        transform: translateX(4px);
        color: inherit;
    }

    .post-meta {
        display: flex;
        gap: 0.5rem;
        font-size: 0.85rem;
        margin-bottom: 0.5rem;
    }

    .post-title {
        font-size: 1.3rem;
        margin: 0 0 0.4rem;
        color: var(--text-strong);
    }

    .post-item:hover .post-title {
        color: var(--accent);
    }

    .post-summary {
        color: var(--text-muted);
        margin-bottom: 0.8rem;
    }
</style>
