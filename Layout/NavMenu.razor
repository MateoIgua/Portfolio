@inject ThemeService Theme
@implements IDisposable

<nav class="navbar">
    <div class="container navbar-inner">
        <a href="" class="brand">
            <span class="brand-bracket">&lt;</span>mateo<span class="brand-bracket">/&gt;</span>
        </a>

        <ul class="nav-links">
            <li><NavLink href="" Match="NavLinkMatch.All">Inicio</NavLink></li>
            <li><NavLink href="about">Sobre mí</NavLink></li>
            <li><NavLink href="projects">Proyectos</NavLink></li>
            <li><NavLink href="blog">Blog</NavLink></li>
        </ul>

        <button class="theme-toggle" @onclick="ToggleTheme" aria-label="Cambiar tema" title="Cambiar tema">
            @if (Theme.CurrentTheme == "dark")
            {
                <span>☀</span>
            }
            else
            {
                <span>☾</span>
            }
        </button>
    </div>
</nav>

@code {
    protected override void OnInitialized()
    {
        Theme.OnThemeChanged += StateHasChanged;
    }

    private async Task ToggleTheme()
    {
        await Theme.ToggleAsync();
    }

    public void Dispose()
    {
        Theme.OnThemeChanged -= StateHasChanged;
    }
}
