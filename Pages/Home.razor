@page "/"

<PageTitle>Mateo | Portafolio</PageTitle>

<section class="hero section">
    <div class="container hero-inner">
        <p class="hero-greeting mono">Hola, soy</p>
        <h1>Mateo<span class="accent">.</span></h1>
        <h2 class="hero-tagline">Desarrollador <span class="accent">.NET</span> &amp; C#</h2>
        <p class="hero-bio">
            Construyo software backend, herramientas y servicios web con C# y .NET.
            Me apasiona el código limpio, la arquitectura sensata y resolver
            problemas reales con tecnología.
        </p>

        <div class="hero-cta">
            <a href="projects" class="btn btn-primary">Ver proyectos →</a>
            <a href="about" class="btn btn-secondary">Sobre mí</a>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <h2>Stack favorito</h2>
        <div class="stack-grid">
            <div class="stack-card">
                <h3>Backend</h3>
                <p>C#, .NET, ASP.NET Core, Entity Framework</p>
            </div>
            <div class="stack-card">
                <h3>Frontend</h3>
                <p>Blazor (WebAssembly &amp; Server), HTML, CSS</p>
            </div>
            <div class="stack-card">
                <h3>Datos</h3>
                <p>SQL Server, PostgreSQL, LINQ</p>
            </div>
            <div class="stack-card">
                <h3>Herramientas</h3>
                <p>Git, Visual Studio, VS Code, Docker</p>
            </div>
        </div>
    </div>
</section>

<style>
    .hero {
        padding: 6rem 0 3rem;
    }

    .hero-greeting {
        color: var(--accent);
        margin: 0 0 1rem;
        font-size: 1rem;
    }

    .hero h1 {
        margin: 0 0 0.5rem;
        color: var(--text-strong);
    }

    .hero-tagline {
        color: var(--text-muted);
        font-weight: 500;
        margin-bottom: 1.5rem;
    }

    .hero-bio {
        max-width: 600px;
        font-size: 1.1rem;
        margin-bottom: 2rem;
    }

    .hero-cta {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .stack-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1rem;
        margin-top: 2rem;
    }

    .stack-card {
        background: var(--surface);
        border: 1px solid var(--border);
        padding: 1.25rem 1.5rem;
        border-radius: 10px;
        transition: all 0.2s ease;
    }

    .stack-card:hover {
        border-color: var(--accent);
        transform: translateY(-2px);
    }

    .stack-card h3 {
        font-size: 1rem;
        color: var(--accent);
        margin-bottom: 0.4rem;
        font-family: 'JetBrains Mono', monospace;
    }

    .stack-card p {
        margin: 0;
        font-size: 0.9rem;
    }
</style>
